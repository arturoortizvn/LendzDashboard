# Monday API (server-side only — never VITE_*)
MONDAY_API_TOKEN=
# One dedicated Monday board per module (read whole, no module-column routing).
# Blank/absent = that module is hidden until its board exists.
ID_MONDAY_PE=18420951236
ID_MONDAY_UW=18420951193
ID_MONDAY_BANK=18420951194
ID_MONDAY_ID=18420951197
ID_MONDAY_PL=18420951201
ID_MONDAY_PAYSTUB=18420951200
# Set these when the corresponding boards exist (module stays hidden until then):
# ID_MONDAY_VT=
# ID_MONDAY_LEXI=
# ID_MONDAY_TAX=
# Azure Blob Storage account name (required). Access is via Managed Identity
# (DefaultAzureCredential) — no account keys or SAS tokens in env.
AZURE_STORAGE_ACCOUNT=
# Optional — blob container for readiness payloads. Defaults to `readiness`.
AZURE_BLOB_CONTAINER=readiness
# Optional — HTTP port for the Express server. Defaults to 3000.
PORT=3000
