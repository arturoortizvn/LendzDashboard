# Monday API (server-side only — never VITE_*)
MONDAY_API_TOKEN=
# Stories board id
ID_MONDAY=18402839374
# Analyzers board id
ID_MONDAY_ANALYZERS=18403908550
# id of the "Module" status column on the Stories board (set after creating it)
MONDAY_MODULE_COLUMN_ID=
# id of the "Module" status column on the Analyzers board (set after the team creates it)
MONDAY_ANALYZER_COLUMN_ID=
# shared secret guarding /api/refresh (Vercel sends it as `Authorization: Bearer <CRON_SECRET>`)
CRON_SECRET=
# injected automatically when the Vercel Blob store is linked
BLOB_READ_WRITE_TOKEN=
# Clerk publishable key (PUBLIC by design — safe in the client bundle)
VITE_CLERK_PUBLISHABLE_KEY=
# Clerk secret key (server-side only — never VITE_*, used to verify session tokens)
CLERK_SECRET_KEY=
# Clerk authorized parties: comma-separated origin allowlist for the token `azp` claim.
# Empty disables the check; the deployment's own Vercel origins are always allowed (server-side only).
CLERK_AUTHORIZED_PARTIES=
