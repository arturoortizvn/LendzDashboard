+})
+
+test('flags exactly the assumed modules', () => {
+  const assumed = MODULES.filter((m) => m.phase === 'delivery' && m.assumed).map((m) => m.key)
+  expect(assumed.sort()).toEqual(['id', 'tax', 'vt'])
+})
