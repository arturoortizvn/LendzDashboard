{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "outDir": "dist-server",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["server", "api", "shared"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "node_modules", "dist", "dist-server", "src"]
}
